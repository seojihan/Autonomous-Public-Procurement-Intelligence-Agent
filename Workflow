      "parameters": {
        "jsCode": "// 1. DB에서 가져온 오늘치 상세 공고 리스트 (이전 노드: Get many rows1)\nconst allItems = $input.all().map(i => i.json);\n\n// 2. 현재 루프를 돌고 있는 사장님 프로필 가져오기 (노드 이름 user loof 확인 ⭐)\nconst profile = $(\"user loof\").item.json;\n\n// 3. 중복 제거 (공고번호 bid_no 기준) - 중복 발송 방지\nconst uniqueBids = Array.from(new Map(allItems.map(b => [b.bid_no, b])).values());\n\n// 4. AI에게 넘길 '초정밀 데이터' 가공\nconst processedBids = uniqueBids.map(b => {\n    const lic = b.license_limit;\n    const reg = b.region_limit;\n    const itm = b.purchase_items;\n\n    // 면허, 지역, 품목 데이터를 AI 가독성 좋게 변환\n    const licenseText = (Array.isArray(lic) && lic.length > 0) \n        ? lic.map(l => l.lcnsLmtNm || l.licenseNm).join(\", \") : \"FACT_MISSING\";\n    \n    const regionText = (Array.isArray(reg) && reg.length > 0) \n        ? reg.map(r => r.prtcptPsblRgnNm || r.regionNm).join(\", \") : \"FACT_MISSING\";\n    \n    const itemsText = (Array.isArray(itm) && itm.length > 0) \n        ? itm.map(it => it.itemNm).join(\", \") : \"FACT_MISSING\";\n\n    return {\n        bid_no: b.bid_no,\n        bid_name: b.bid_name,\n        budget: b.price || 0, \n        participation_fee: b.participation_fee || 0,\n        deadline: b.deadline || b.bidClseDt || \"공고문 확인 필수\",\n        link: b.detail_url,\n        \n        // 팩트 데이터 전달\n        license_fact: licenseText,\n        region_fact: regionText,\n        items_fact: itemsText,\n        \n        // 🔥 [진실의 조각] 한글 파일 원문 데이터 포함!\n        rfp_content: b.rfp_text || \"공고서 파일 원문 데이터 지연 중(링크 확인 권장)\",\n        \n        joint_bidding: b.joint_bidding || (b.jointRqstYn === 'Y' ? \"허용\" : \"불허\"),\n        basis_price: b.basis_price || 0,\n        change_count: b.change_count || 0,\n        file_urls: b.file_links || \"상세페이지 확인\"\n    };\n});\n\n// 5. 적합도 정렬 (IT 키워드 최우선)\nprocessedBids.sort((a, b) => {\n    const aIT = (a.bid_name.includes(\"시스템\") || a.items_fact.includes(\"시스템\")) ? 1 : 0;\n    const bIT = (b.bid_name.includes(\"시스템\") || b.items_fact.includes(\"시스템\")) ? 1 : 0;\n    return bIT - aIT;\n});\n\n// 6. 최종 보따리 반환 (정예 3건으로 압축)\nreturn [{\n    company_info: profile,\n    today_bids: processedBids.slice(0, 3), \n    bid_count: uniqueBids.length,\n    report_date: new Date().toLocaleDateString('ko-KR')\n}];"
