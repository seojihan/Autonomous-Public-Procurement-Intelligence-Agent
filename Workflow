      "parameters": {
        "jsCode": "const allItems = $input.all().map(i => i.json);\nconst profile = $(\"user loof\").item.json;\nconst uniqueBids = Array.from(new Map(allItems.map(b => [b.bid_no, b])).values());\n\nconst processedBids = uniqueBids.map(b => {\n    const lic = b.license_limit;\n    const reg = b.region_limit;\n    const itm = b.purchase_items;\n\n    const licenseText = (Array.isArray(lic) && lic.length > 0) \n        ? lic.map(l => l.lcnsLmtNm || l.licenseNm).join(\", \") : \"FACT_MISSING\";\n    \n    const regionText = (Array.isArray(reg) && reg.length > 0) \n        ? reg.map(r => r.prtcptPsblRgnNm || r.regionNm).join(\", \") : \"FACT_MISSING\";\n    \n    const itemsText = (Array.isArray(itm) && itm.length > 0) \n        ? itm.map(it => it.itemNm).join(\", \") : \"FACT_MISSING\";\n\n    return {\n        bid_no: b.bid_no,\n        bid_name: b.bid_name,\n        budget: b.price || 0, \n        participation_fee: b.participation_fee || 0,\n        deadline: b.deadline || b.bidClseDt || \"공고문 확인 필수\",\n        link: b.detail_url,\n        license_fact: licenseText,\n        region_fact: regionText,\n        items_fact: itemsText,\n        rfp_content: b.rfp_text || \"공고서 파일 원문 데이터 지연 중(링크 확인 권장)\",\n        joint_bidding: b.joint_bidding || (b.jointRqstYn === 'Y' ? \"허용\" : \"불허\"),\n        basis_price: b.basis_price || 0,\n        change_count: b.change_count || 0,\n        file_urls: b.file_links || \"상세페이지 확인\"\n    };\n});\n\nprocessedBids.sort((a, b) => {\n    const aIT = (a.bid_name.includes(\"시스템\") || a.items_fact.includes(\"시스템\")) ? 1 : 0;\n    const bIT = (b.bid_name.includes(\"시스템\") || b.items_fact.includes(\"시스템\")) ? 1 : 0;\n    return bIT - aIT;\n});\n\nreturn [{\n    company_info: profile,\n    today_bids: processedBids.slice(0, 3), \n    bid_count: uniqueBids.length,\n    report_date: new Date().toLocaleDateString('ko-KR')\n}];"
